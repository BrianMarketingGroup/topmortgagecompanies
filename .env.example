# Google Sheets — base64-encoded service account JSON
# Run: base64 -i your-service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=

# The ID of the Google Sheet where leads are stored (from the Sheet URL)
# Applications go to the "Applications" tab, contact form to "Contact" tab
LEADS_SHEET_ID=

# Sales inbox to receive lead notification emails (comma-separated for multiple)
SALES_INBOX_EMAIL=sales@topmortgagecompanies.com

# SendGrid API key
SENDGRID_API_KEY=

# Public site URL (used in emails and traffic source tracking)
NEXT_PUBLIC_SITE_URL=https://topmortgagecompanies.com

# big-swing-bff base URL — apply submissions are POSTed to {URL}/api/v1/deals.
# The BFF persists the deal to Postgres AND mirrors it to this platform's Google
# Sheet (resolved from platform_id). Leave empty to disable.
BIG_SWING_BFF_URL=

# This site's platforms row id in the Big Swing DB. Sent as platform_id so the
# BFF sets deals.platform_id and resolves the destination sheet (platforms.sheet_id).
BIG_SWING_PLATFORM_ID=
